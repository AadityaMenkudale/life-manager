// This is your Prisma schema file
// SQLite compatible - uses String instead of enums

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── USER ────────────────────────────────────────────────────────────────────
model User {
  id               String   @id @default(uuid())
  email            String   @unique
  username         String   @unique
  passwordHash     String
  displayName      String
  avatarSeed       String   @default("default")
  dailyCalorieGoal Int      @default(2000)
  dailyStepGoal    Int      @default(10000)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  tasks      Task[]
  habits     Habit[]
  habitLogs  HabitLog[]
  workouts   Workout[]
  meals      Meal[]
  reminders  Reminder[]
  dailyStats DailyStats[]

  @@map("users")
}

// ─── TASKS ───────────────────────────────────────────────────────────────────
// priority: LOW | MEDIUM | HIGH | URGENT
// status:   PENDING | IN_PROGRESS | COMPLETED | CANCELLED
model Task {
  id          String    @id @default(uuid())
  userId      String
  title       String
  description String?
  priority    String    @default("MEDIUM")
  status      String    @default("PENDING")
  dueDate     DateTime?
  dueTime     String?
  tags        String?
  completedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, status])
  @@map("tasks")
}

// ─── HABITS ──────────────────────────────────────────────────────────────────
// category:  HEALTH | FITNESS | MINDSET | LEARNING | SOCIAL | NUTRITION | OTHER
// frequency: DAILY | WEEKLY | MONTHLY
model Habit {
  id           String   @id @default(uuid())
  userId       String
  name         String
  description  String?
  icon         String   @default("star")
  color        String   @default("blue")
  category     String   @default("HEALTH")
  frequency    String   @default("DAILY")
  targetCount  Int      @default(1)
  reminderTime String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs HabitLog[]

  @@index([userId])
  @@map("habits")
}

model HabitLog {
  id       String   @id @default(uuid())
  habitId  String
  userId   String
  date     String
  count    Int      @default(1)
  note     String?
  loggedAt DateTime @default(now())

  habit Habit @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([habitId, date])
  @@index([userId, date])
  @@map("habit_logs")
}

// ─── WORKOUTS ────────────────────────────────────────────────────────────────
// type: CARDIO | STRENGTH | YOGA | HIIT | SWIMMING | CYCLING | RUNNING | WALKING | SPORTS | OTHER
model Workout {
  id             String   @id @default(uuid())
  userId         String
  name           String
  type           String   @default("OTHER")
  durationMins   Int
  caloriesBurned Int      @default(0)
  sets           Int?
  reps           Int?
  weightKg       Float?
  distanceKm     Float?
  notes          String?
  loggedAt       DateTime @default(now())
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, loggedAt])
  @@map("workouts")
}

// ─── MEALS ───────────────────────────────────────────────────────────────────
// mealType: BREAKFAST | LUNCH | DINNER | SNACK | PRE_WORKOUT | POST_WORKOUT
model Meal {
  id          String   @id @default(uuid())
  userId      String
  name        String
  mealType    String   @default("SNACK")
  calories    Int
  proteinG    Float    @default(0)
  carbsG      Float    @default(0)
  fatG        Float    @default(0)
  servingSize String?
  notes       String?
  loggedAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, loggedAt])
  @@map("meals")
}

// ─── REMINDERS ───────────────────────────────────────────────────────────────
// type: WORKOUT | MEAL | HABIT | TASK | WATER | SLEEP | CUSTOM
model Reminder {
  id          String    @id @default(uuid())
  userId      String
  title       String
  description String?
  type        String    @default("CUSTOM")
  time        String
  days        String
  isActive    Boolean   @default(true)
  lastFiredAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("reminders")
}

// ─── DAILY STATS ─────────────────────────────────────────────────────────────
model DailyStats {
  id                   String   @id @default(uuid())
  userId               String
  date                 String
  tasksTotal           Int      @default(0)
  tasksCompleted       Int      @default(0)
  habitsTotal          Int      @default(0)
  habitsCompleted      Int      @default(0)
  caloriesConsumed     Int      @default(0)
  caloriesBurned       Int      @default(0)
  workoutMinutes       Int      @default(0)
  steps                Int      @default(0)
  lifePerformanceScore Int      @default(0)
  calculatedAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId])
  @@map("daily_stats")
}
